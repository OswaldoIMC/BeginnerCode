{
  "expo": {
    "name": "BeginnerCode",
    "slug": "BeginnerCode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Login_Image_NoBG.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Login_Image_NoBG.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.oswaldoimc.BeginnerCode"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "1a2fa72f-0b18-4c7e-aebc-c5b2d657af9e"
      }
    }
  }
}
